{
  "expo": {
    "name": "Maricá FC",
    "shortName": "Maricá FC",
    "slug": "marica-fc-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/escudo-redondo-04.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F4F0"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/escudo-redondo-04.png",
        "backgroundColor": "#F4F4F0"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/escudo-redondo-04.png",
      "themeColor": "#002147",
      "backgroundColor": "#F4F4F0",
      "display": "standalone",
      "pwa": {
        "appleTouchIcon": "./assets/images/escudo-redondo-04.png"
      },
      "meta": {
        "viewport": "width=device-width, initial-scale=1, viewport-fit=cover",
        "og:image": "https://marica-fc-app.vercel.app/assets/images/escudo-redondo-04.png",
        "og:title": "Maricá FC • Portal do Sócio",
        "og:description": "O portal oficial do sócio torcedor do Maricá FC. Notícias, tabela, planos e muito mais.",
        "og:type": "website",
        "twitter:card": "summary_large_image",
        "twitter:image": "https://marica-fc-app.vercel.app/assets/images/escudo-redondo-04.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-video"
    ],
    "scheme": "marica-fc-app"
  }
}
