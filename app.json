{
  "expo": {
    "name": "Maricá FC",
    "slug": "marica-fc-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F4F0"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F4F4F0"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/escudo-redondo-04.png",
      "meta": {
        "og:image":       "https://marica-fc-app.vercel.app/assets/images/escudo-redondo-04.png",
        "og:title":       "Maricá FC • Portal do Sócio",
        "og:description": "O portal oficial do sócio torcedor do Maricá FC. Notícias, tabela, planos e muito mais.",
        "og:type":        "website",
        "twitter:card":   "summary_large_image",
        "twitter:image":  "https://marica-fc-app.vercel.app/assets/images/escudo-redondo-04.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-video"
    ],
    "scheme": "marica-fc-app"
  }
}
