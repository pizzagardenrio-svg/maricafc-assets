rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Qualquer pessoa pode ver as imagens / ler arquivos.
    // Apenas usuários logados podem subir arquivos.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Caso o usuário queira atualizar sua foto de perfil
    // Bloqueamos uploads de usuários não logados, e a regra
    // de tamanho serve para poupar espaço.
    match /users/{userId}/{allImages=**} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024; // 5MB MAX
    }
  }
}
